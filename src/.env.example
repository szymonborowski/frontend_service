APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=frontend-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# OVH SMTP — ssl0.ovh.net:465 (SSL) or ssl0.ovh.net:587 (STARTTLS)
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=ssl0.ovh.net
MAIL_PORT=465
MAIL_USERNAME=szymon@borowski.services
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="szymon@borowski.services"
MAIL_FROM_NAME="Szymon Borowski"
MAIL_CONTACT_TO="szymon@borowski.services"

NEWSLETTER_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Microservices URLs
SSO_URL=https://sso.microservices.local
SSO_API_URL_INTERNAL=http://sso-nginx
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

BLOG_API_URL=https://blog.microservices.local
BLOG_API_URL_INTERNAL=http://blog-nginx
BLOG_FRONTEND_URL=https://frontend.microservices.local/blog

USERS_API_URL_INTERNAL=http://users-nginx
USERS_INTERNAL_API_KEY=

ANALYTICS_API_URL_INTERNAL=http://analytics-nginx
ANALYTICS_INTERNAL_API_KEY=

ADMIN_URL=https://admin.microservices.local

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024

VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

QDRANT_HOST=frontend-qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=portfolio_posts

# Meilisearch master key (must match blog service)
MEILISEARCH_MASTER_KEY=
