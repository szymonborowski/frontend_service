APP_NAME=Frontend
APP_ENV=local
APP_DEBUG=true
APP_URL=https://frontend.microservices.local
APP_DOMAIN=frontend.microservices.local

UID=1000
GID=1000

# PHP
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=50M

# Nginx
NGINX_PORT=80

NETWORK_NAME=web

# Session / Cache
SESSION_DRIVER=redis
CACHE_STORE=redis

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=

# SSO
SSO_URL=https://sso.microservices.local
SSO_API_URL_INTERNAL=http://sso-nginx
SSO_CLIENT_ID=frontend-client
SSO_CLIENT_SECRET=

# Internal services (defaults work in Docker Compose)
BLOG_API_URL_INTERNAL=http://blog-nginx
USERS_API_URL_INTERNAL=http://users-nginx
USERS_INTERNAL_API_KEY=

# Analytics
ANALYTICS_API_URL_INTERNAL=http://analytics-nginx
ANALYTICS_INTERNAL_API_KEY=
